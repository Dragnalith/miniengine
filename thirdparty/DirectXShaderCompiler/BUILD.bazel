load("//build/rules:shader_toolchain.bzl", "shader_toolchain")

package(default_visibility = ["//visibility:public"])

filegroup(
    name = "dxc_runtime",
    srcs = [
        "bin/x64/dxcompiler.dll",
        "bin/x64/dxil.dll",
    ],
)

shader_toolchain(
    name = "dxc_dxil_toolchain_impl",
    compiler = "bin/x64/dxc.exe",
    compiler_files = [":dxc_runtime"],
    extension = ".shaderb",
    format = "dxil",
)

shader_toolchain(
    name = "dxc_spirv_toolchain_impl",
    compiler = "bin/x64/dxc.exe",
    compiler_files = [":dxc_runtime"],
    default_copts = ["-spirv"],
    extension = ".shaderb",
    format = "spirv",
)

toolchain(
    name = "dxc_dxil_toolchain",
    exec_compatible_with = [
        "@platforms//cpu:x86_64",
        "@platforms//os:windows",
    ],
    target_compatible_with = ["@platforms//os:windows"],
    toolchain = ":dxc_dxil_toolchain_impl",
    toolchain_type = "//build/rules:shader_toolchain_type",
)

toolchain(
    name = "dxc_spirv_toolchain",
    exec_compatible_with = [
        "@platforms//cpu:x86_64",
        "@platforms//os:windows",
    ],
    target_compatible_with = ["@platforms//os:android"],
    toolchain = ":dxc_spirv_toolchain_impl",
    toolchain_type = "//build/rules:shader_toolchain_type",
)
